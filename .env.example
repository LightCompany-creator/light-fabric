# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Только для админ-скриптов (seed-users.mjs, import-data.mjs и т.п.).
# НЕ использовать в коде приложения — даёт полный доступ в обход RLS.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Подключение к Postgres напрямую — нужно только для прогонки SQL-миграций
# через scripts/run-migrations.mjs. Берётся в Supabase Dashboard:
# Connect → Direct → Session pooler → Connection string → URI.
DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-X-REGION.pooler.supabase.com:5432/postgres
